<Window x:Class="AqiClock.App.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Admin — AQI Clock" Width="1050" Height="720" WindowStartupLocation="CenterOwner">
    <Window.Resources><BooleanToVisibilityConverter x:Key="BoolToVisibility" /></Window.Resources>
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" Text="{Binding Banner}" Foreground="#D14343" Margin="0,0,0,8" />
        <TabControl IsEnabled="{Binding IsOnline}">
            <TabItem Header="Timetables">
                <Grid DataContext="{Binding Timetables}" Margin="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="240" /><ColumnDefinition /></Grid.ColumnDefinitions>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                            <Button Content="New" Command="{Binding NewTimetableCommand}" />
                            <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
                            <Button Content="Archive / restore" Command="{Binding ToggleArchiveCommand}" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" DisplayMemberPath="Name" />
                    </DockPanel>
                    <DockPanel Grid.Column="1" Margin="16,0,0,0">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding ValidationMessage}" Foreground="#D14343" />
                            <TextBlock Text="{Binding WarningMessage}" Foreground="#C77C00" />
                            <Border Background="#FFF4CE" Padding="8" Visibility="{Binding HasConflict, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="Changed remotely just now — " /><Button Content="Reload" Command="{Binding ReloadCommand}" /><Button Content="Overwrite" Command="{Binding OverwriteCommand}" /></StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                            <Button Content="Add period" Command="{Binding AddPeriodCommand}" />
                            <Button Content="Save" Command="{Binding SaveCommand}" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                            <Button Content="Delete timetable" Command="{Binding DeleteCommand}" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Periods}" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                                <DataGridTextColumn Header="Start" Binding="{Binding Start}" />
                                <DataGridTextColumn Header="End" Binding="{Binding End}" />
                                <DataGridCheckBoxColumn Header="Lesson?" Binding="{Binding IsLesson}" />
                                <DataGridTemplateColumn Header="Order"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Content="↑" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><Button Content="↓" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><Button Content="Delete" Command="{Binding DataContext.RemovePeriodCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Week schedule">
                <DataGrid DataContext="{Binding WeekSchedule}" ItemsSource="{Binding Rows}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Day" Binding="{Binding Day}" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Timetable"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox MinWidth="220" ItemsSource="{Binding DataContext.Timetables, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TimetableId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Content="No school" Command="{Binding DataContext.SetNoSchoolCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><Button Content="Save" Command="{Binding DataContext.SaveRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><TextBlock Text="{Binding Error}" Foreground="#D14343" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Date overrides">
                <DockPanel DataContext="{Binding Overrides}" Margin="10">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><Button Content="Add override" Command="{Binding AddCommand}" /><CheckBox Content="Show past" IsChecked="{Binding ShowPast}" Margin="16,0" /></StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Error}" Foreground="#D14343" />
                    <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" />
                            <DataGridTemplateColumn Header="Timetable / Closed"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ComboBox MinWidth="220" ItemsSource="{Binding DataContext.Timetables, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TimetableId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><Button Content="Closed" Command="{Binding DataContext.SetClosedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" />
                            <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Content="Save" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><Button Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Announcements">
                <Grid DataContext="{Binding Announcements}" Margin="10"><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition /></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Compose announcement" FontWeight="SemiBold" /><TextBox Text="{Binding Title}" MaxLength="200" /><TextBox Text="{Binding Body}" MaxLength="2000" AcceptsReturn="True" Height="90" /><ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding Expiry}" /><Button Content="Publish" Command="{Binding PublishCommand}" HorizontalAlignment="Left" /><TextBlock Text="{Binding Error}" Foreground="#D14343" /></StackPanel>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Items}"><ListBox.ItemTemplate><DataTemplate><DockPanel><Button DockPanel.Dock="Right" Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" /><TextBlock Text="{Binding Title}" /></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox>
                </Grid>
            </TabItem>
            <TabItem Header="Recent changes"><DockPanel DataContext="{Binding Audit}" Margin="10"><Button DockPanel.Dock="Top" Content="Refresh" Command="{Binding LoadCommand}" HorizontalAlignment="Left" /><TextBlock DockPanel.Dock="Top" Text="{Binding Message}" /><DataGrid ItemsSource="{Binding Items}" IsReadOnly="True" AutoGenerateColumns="True" /></DockPanel></TabItem>
            <TabItem Header="Users"><DockPanel DataContext="{Binding Users}" Margin="10"><TextBlock DockPanel.Dock="Top" Text="Invitations are managed in the Supabase dashboard for the MVP. Other users' email addresses are not stored in profiles." /><DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding DisplayName, Mode=OneWay}" IsReadOnly="True" /><DataGridTextColumn Header="Email" Binding="{Binding Email, Mode=OneWay}" IsReadOnly="True" /><DataGridTemplateColumn Header="Role"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding DataContext.Roles, RelativeSource={RelativeSource AncestorType=DataGrid}}" SelectedItem="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel><Button Content="Save" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><TextBlock Text="{Binding Error}" Foreground="#D14343" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid></DockPanel></TabItem>
        </TabControl>
    </DockPanel>
</Window>
