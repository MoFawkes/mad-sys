<ui:FluentWindow x:Class="AqiClock.App.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Admin — AQI Clock"
        Width="1120"
        Height="780"
        MinWidth="960"
        MinHeight="640"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource CardBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource CardBrush}" />
            <Setter Property="RowHeight" Value="36" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource CurrentPeriodBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource CardBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
        </Style>
    </ui:FluentWindow.Resources>
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition /></Grid.RowDefinitions>
        <ui:TitleBar Title="AQI Clock administration" />
    <DockPanel Grid.Row="1" Margin="22,12,22,22">
        <ui:InfoBar DockPanel.Dock="Top"
                    IsOpen="{Binding HasBanner}"
                    Severity="Error"
                    Title="Administration unavailable"
                    Message="{Binding Banner}"
                    Margin="0,0,0,10" />
        <TabControl IsEnabled="{Binding IsOnline}">
            <TabItem Header="Timetables">
                <Grid DataContext="{Binding Timetables}" Margin="10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="240" /><ColumnDefinition /></Grid.ColumnDefinitions>
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                            <ui:Button Content="New" Command="{Binding NewTimetableCommand}" Appearance="Primary" />
                            <Button Content="Duplicate" Command="{Binding DuplicateCommand}" />
                            <Button Content="Archive / restore" Command="{Binding ToggleArchiveCommand}" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}" DisplayMemberPath="Name" />
                    </DockPanel>
                    <DockPanel Grid.Column="1" Margin="16,0,0,0">
                        <StackPanel DockPanel.Dock="Top">
                            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource ErrorBrush}" />
                            <TextBlock Text="{Binding WarningMessage}" Foreground="{DynamicResource WarningBrush}" />
                            <Border Background="{DynamicResource WarningBackgroundBrush}" CornerRadius="8" Padding="10" Visibility="{Binding HasConflict, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal"><TextBlock Text="Changed remotely just now — " /><Button Content="Reload" Command="{Binding ReloadCommand}" /><Button Content="Overwrite" Command="{Binding OverwriteCommand}" /></StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
                            <Button Content="Add period" Command="{Binding AddPeriodCommand}" />
                            <ui:Button Content="Save" Command="{Binding SaveCommand}" Appearance="Primary" />
                            <Button Content="Cancel" Command="{Binding CancelCommand}" />
                            <ui:Button Content="Delete timetable" Command="{Binding DeleteCommand}" Appearance="Danger" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding Periods}" AutoGenerateColumns="False" CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" />
                                <DataGridTextColumn Header="Start" Binding="{Binding Start}" />
                                <DataGridTextColumn Header="End" Binding="{Binding End}" />
                                <DataGridCheckBoxColumn Header="Lesson?" Binding="{Binding IsLesson}" />
                                <DataGridTemplateColumn Header="Order"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ui:Button Content="↑" ToolTip="Move up" Appearance="Transparent" Width="32" Height="32" Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><ui:Button Content="↓" ToolTip="Move down" Appearance="Transparent" Width="32" Height="32" Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><ui:Button Content="✕" ToolTip="Delete period" Appearance="Danger" Width="32" Height="32" Command="{Binding DataContext.RemovePeriodCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Week schedule">
                <DataGrid DataContext="{Binding WeekSchedule}" ItemsSource="{Binding Rows}" AutoGenerateColumns="False" CanUserAddRows="False" Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Day" Binding="{Binding Day}" IsReadOnly="True" />
                        <DataGridTemplateColumn Header="Timetable"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox MinWidth="220" ItemsSource="{Binding DataContext.Timetables, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TimetableId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Content="No school" Command="{Binding DataContext.SetNoSchoolCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><Button Content="Save" Command="{Binding DataContext.SaveRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Date overrides">
                <DockPanel DataContext="{Binding Overrides}" Margin="10">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><ui:Button Content="Add override" Command="{Binding AddCommand}" Appearance="Primary" /><CheckBox Content="Show past" IsChecked="{Binding ShowPast}" Margin="16,0" /></StackPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" />
                    <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" />
                            <DataGridTemplateColumn Header="Timetable / Closed"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ComboBox MinWidth="220" ItemsSource="{Binding DataContext.Timetables, RelativeSource={RelativeSource AncestorType=DataGrid}}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding TimetableId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><Button Content="Closed" Command="{Binding DataContext.SetClosedCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTextColumn Header="Note" Binding="{Binding Note}" />
                            <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ui:Button Content="Save" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Appearance="Primary" /><ui:Button Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Appearance="Danger" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="Classes / Audiences">
              <Grid DataContext="{Binding Classes}" Margin="10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="1.3*"/></Grid.ColumnDefinitions>
                <DockPanel Margin="0,0,10,0"><ui:Button DockPanel.Dock="Top" Content="Add class" Command="{Binding AddCommand}" HorizontalAlignment="Left"/>
                  <TextBlock DockPanel.Dock="Top" Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}"/>
                  <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False"><DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/><DataGridTextColumn Header="Order" Binding="{Binding SortOrder, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ui:Button Content="Save" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/><ui:Button Content="Delete" Appearance="Danger" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Margin="4,0,0,0"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                  </DataGrid.Columns></DataGrid></DockPanel>
                <DataGrid Grid.Column="1" ItemsSource="{Binding PeriodTags}" AutoGenerateColumns="False" CanUserAddRows="False"><DataGrid.Columns>
                  <DataGridTextColumn Header="Period" Binding="{Binding PeriodName}" IsReadOnly="True"/><DataGridTextColumn Header="Classes (comma-separated)" Binding="{Binding ClassNames, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                  <DataGridTemplateColumn Width="260"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><ui:Button Content="Save tags" Command="{Binding DataContext.SaveTagsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/><TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="150" Margin="8,0,0,0"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                </DataGrid.Columns></DataGrid>
              </Grid>
            </TabItem>
            <TabItem Header="Announcements">
                <TabControl DataContext="{Binding Announcements}" Margin="10">
                  <TabItem Header="Compose"><ScrollViewer><StackPanel Margin="8">
                    <TextBlock Text="Compose announcement" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Title}" MaxLength="200" Margin="0,8,0,0" />
                    <TextBox Text="{Binding Body}" MaxLength="2000" AcceptsReturn="True" Height="90" Margin="0,8,0,0" />
                    <TextBlock Text="Audience" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,2"/><ComboBox ItemsSource="{Binding Audiences}" SelectedItem="{Binding Audience}" />
                    <ComboBox ItemsSource="{Binding Classes}" DisplayMemberPath="Name" SelectedValuePath="Id" SelectedValue="{Binding AudienceClassId}" Margin="0,6,0,0"/>
                    <TextBlock Text="Update type" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,2"/><ComboBox ItemsSource="{Binding UpdateTypes}" SelectedItem="{Binding UpdateType}"/>
                    <TextBlock Text="Publish date/time (optional)" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,2"/>
                    <StackPanel Orientation="Horizontal"><DatePicker SelectedDate="{Binding PublishAt}" Width="180"/><TextBox Text="{Binding PublishTime}" Width="90" Margin="8,0,0,0" ToolTip="Time in HH:mm format"/></StackPanel>
                    <TextBox Text="{Binding EMasjidLink}" Margin="0,8,0,0" ToolTip="Optional HTTPS e-Masjid link"/>
                    <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding Expiry}" Margin="0,8,0,0"/>
                    <ui:Button Content="Publish or schedule" Command="{Binding PublishCommand}" Appearance="Primary" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    <TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" />
                  </StackPanel></ScrollViewer></TabItem>
                  <TabItem Header="Active"><ListBox ItemsSource="{Binding Items}"><ListBox.ItemTemplate><DataTemplate><DockPanel><ui:Button DockPanel.Dock="Right" Content="Delete" Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}" Appearance="Danger" /><StackPanel><TextBlock Text="{Binding Title}"/><TextBlock Text="{Binding AudienceType}" Foreground="{DynamicResource MutedBrush}"/></StackPanel></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
                  <TabItem Header="Scheduled &amp; history"><ListBox ItemsSource="{Binding History}"><ListBox.ItemTemplate><DataTemplate><DockPanel><ui:Button DockPanel.Dock="Right" Content="Publish now" IsEnabled="{Binding CanPublishFromHistory}" Command="{Binding DataContext.PublishItemCommand, RelativeSource={RelativeSource AncestorType=ListBox}}" CommandParameter="{Binding}"/><StackPanel><TextBlock Text="{Binding Title}"/><TextBlock Text="{Binding Status}" Foreground="{DynamicResource MutedBrush}"/></StackPanel></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox></TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="Recent changes"><DockPanel DataContext="{Binding Audit}" Margin="10"><ui:Button DockPanel.Dock="Top" Content="Refresh" Command="{Binding LoadCommand}" Appearance="Primary" HorizontalAlignment="Left" /><TextBlock DockPanel.Dock="Top" Text="{Binding Message}" /><DataGrid ItemsSource="{Binding Items}" IsReadOnly="True" AutoGenerateColumns="True" /></DockPanel></TabItem>
            <TabItem Header="Profiles / Audiences"><DockPanel DataContext="{Binding Users}" Margin="10"><TextBlock DockPanel.Dock="Top" Text="Invitations are managed in the Supabase dashboard for the MVP. Other users' email addresses are not stored in profiles." /><DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" CanUserAddRows="False"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding DisplayName, Mode=OneWay}" IsReadOnly="True" /><DataGridTextColumn Header="Email" Binding="{Binding Email, Mode=OneWay}" IsReadOnly="True" /><DataGridTemplateColumn Header="Role"><DataGridTemplateColumn.CellTemplate><DataTemplate><ComboBox ItemsSource="{Binding DataContext.Roles, RelativeSource={RelativeSource AncestorType=DataGrid}}" SelectedItem="{Binding Role, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" /><DataGridTemplateColumn><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel><ui:Button Content="Save" Appearance="Primary" Command="{Binding DataContext.SaveCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" /><TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" /></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn></DataGrid.Columns></DataGrid></DockPanel></TabItem>
        </TabControl>
    </DockPanel>
    </Grid>
</ui:FluentWindow>
