<Window x:Class="AqiClock.App.Views.PasswordRecoveryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Set password — AQI Clock"
        Width="460"
        Height="480"
        MinWidth="380"
        MinHeight="420"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="42" VerticalAlignment="Center">
            <TextBlock Text="Set a new password" FontSize="28" FontWeight="Bold" />
            <TextBlock Text="Use at least 10 characters."
                       Margin="0,4,0,24"
                       Foreground="{DynamicResource MutedBrush}" />
            <TextBlock Text="New password" />
            <PasswordBox x:Name="NewPassword"
                         PasswordChanged="OnNewPasswordChanged"
                         Margin="0,5,0,14"
                         Padding="8" />
            <TextBlock Text="Confirm password" />
            <PasswordBox x:Name="ConfirmPassword"
                         PasswordChanged="OnConfirmPasswordChanged"
                         Margin="0,5,0,14"
                         Padding="8" />
            <TextBlock Text="{Binding ErrorMessage}"
                       TextWrapping="Wrap"
                       Foreground="#D14343"
                       Margin="0,0,0,8" />
            <TextBlock Text="{Binding ProgressMessage}" TextWrapping="Wrap" />
            <Button Content="Update password"
                    Command="{Binding UpdatePasswordCommand}"
                    IsDefault="True"
                    Margin="0,10,0,4" />
            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    IsCancel="True" />
        </StackPanel>
    </ScrollViewer>
</Window>
