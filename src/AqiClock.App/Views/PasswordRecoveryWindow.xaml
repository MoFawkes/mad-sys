<ui:FluentWindow x:Class="AqiClock.App.Views.PasswordRecoveryWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Set password — AQI Clock"
                 Width="500"
                 Height="590"
                 MinWidth="400"
                 MinHeight="470"
                 ResizeMode="CanResizeWithGrip"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <ui:TitleBar Title="AQI Clock" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="42,24,42,42" VerticalAlignment="Center">
                <Image Source="/AqiClock.App;component/assets/logo.png"
                       Width="64"
                       Height="64"
                       HorizontalAlignment="Left"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="Set a new password"
                           FontSize="{DynamicResource TitleFontSize}"
                           FontWeight="SemiBold"
                           Margin="0,16,0,0" />
                <TextBlock Text="Choose a secure password with at least 10 characters."
                           TextWrapping="Wrap"
                           Margin="0,6,0,24"
                           Foreground="{DynamicResource MutedBrush}" />
                <Border Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="24">
                    <StackPanel>
                        <TextBlock Text="New password" FontWeight="SemiBold" />
                        <PasswordBox x:Name="NewPassword"
                                     PasswordChanged="OnNewPasswordChanged"
                                     Margin="0,6,0,16"
                                     Padding="10,8" />
                        <TextBlock Text="Confirm password" FontWeight="SemiBold" />
                        <PasswordBox x:Name="ConfirmPassword"
                                     PasswordChanged="OnConfirmPasswordChanged"
                                     Margin="0,6,0,8"
                                     Padding="10,8" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource ErrorBrush}"
                                   Margin="0,4,0,8" />
                        <TextBlock Text="{Binding ProgressMessage}"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedBrush}"
                                   Margin="0,0,0,8" />
                        <ui:Button Content="Update password"
                                   Command="{Binding UpdatePasswordCommand}"
                                   Appearance="Primary"
                                   HorizontalAlignment="Stretch"
                                   HorizontalContentAlignment="Center"
                                   IsDefault="True"
                                   Margin="0,8,0,4"
                                   Padding="14,9" />
                        <ui:Button Content="Cancel"
                                   Command="{Binding CancelCommand}"
                                   Appearance="Transparent"
                                   HorizontalAlignment="Center"
                                   IsCancel="True"
                                   Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
