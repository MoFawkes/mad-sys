<ui:FluentWindow x:Class="AqiClock.App.Views.SignInWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Sign in — AQI Clock"
                 Width="500"
                 Height="620"
                 MinWidth="400"
                 MinHeight="480"
                 ResizeMode="CanResizeWithGrip"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </ui:FluentWindow.Resources>
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <ui:TitleBar Title="AQI Clock" />
        <ScrollViewer x:Name="AuthScroller"
                      Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="42,24,42,42">
                <StackPanel VerticalAlignment="Center">
                    <Image Source="/AqiClock.App;component/assets/logo.png"
                           Width="64"
                           Height="64"
                           HorizontalAlignment="Left"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="Welcome to AQI Clock"
                               FontSize="{DynamicResource TitleFontSize}"
                               FontWeight="SemiBold"
                               Margin="0,16,0,0" />
                    <TextBlock Text="Sign in to download your timetable and stay in sync."
                               TextWrapping="Wrap"
                               FontSize="{DynamicResource BodyFontSize}"
                               Margin="0,6,0,24"
                               Foreground="{DynamicResource MutedBrush}" />
                    <Border Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="24">
                        <StackPanel>
                            <TextBlock Text="Email" FontWeight="SemiBold" />
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,6,0,16"
                                     Padding="10,8" />
                            <TextBlock Text="Password" FontWeight="SemiBold" />
                            <PasswordBox x:Name="Password"
                                         PasswordChanged="OnPasswordChanged"
                                         Margin="0,6,0,8"
                                         Padding="10,8" />
                            <TextBlock Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       Visibility="{Binding HasErrorMessage, Converter={StaticResource BoolToVisibility}}"
                                       Margin="0,4,0,8" />
                            <TextBlock Text="{Binding ProgressMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource MutedBrush}"
                                       Visibility="{Binding HasProgressMessage, Converter={StaticResource BoolToVisibility}}"
                                       Margin="0,0,0,8" />
                            <ui:Button Content="Sign in"
                                       Command="{Binding SignInCommand}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Center"
                                       IsDefault="True"
                                       Margin="0,8,0,4"
                                       Padding="14,9" />
                            <ui:Button Content="Forgot password"
                                       Command="{Binding ForgotPasswordCommand}"
                                       Appearance="Transparent"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
