<Window x:Class="AqiClock.App.Views.SignInWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Sign in — AQI Clock" Width="420" Height="430" ResizeMode="NoResize" WindowStartupLocation="CenterScreen"><Grid Margin="42"><Grid.RowDefinitions><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel VerticalAlignment="Center"><TextBlock Text="AQI Clock" FontSize="32" FontWeight="Bold"/><TextBlock Text="Sign in to download your timetable" Margin="0,4,0,24" Foreground="{DynamicResource MutedBrush}"/><TextBlock Text="Email"/><TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,14" Padding="8"/><TextBlock Text="Password"/><PasswordBox x:Name="Password" PasswordChanged="OnPasswordChanged" Margin="0,5,0,14" Padding="8"/><TextBlock Text="{Binding ErrorMessage}" TextWrapping="Wrap" Foreground="#D14343" Margin="0,0,0,8"/><TextBlock Text="{Binding ProgressMessage}"/><Button Content="Sign in" Command="{Binding SignInCommand}" IsDefault="True" Margin="0,10,0,4"/><Button Content="Forgot password" Command="{Binding ForgotPasswordCommand}" Background="Transparent" BorderThickness="0"/></StackPanel></Grid></Window>
