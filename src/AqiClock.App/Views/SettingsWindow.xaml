<ui:FluentWindow x:Class="AqiClock.App.Views.SettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Settings — AQI Clock"
                 Width="700"
                 Height="780"
                 MinWidth="580"
                 MinHeight="620"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid Background="{DynamicResource WindowBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ui:TitleBar Title="Settings" />
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,16,28,24">
                <TextBlock Text="Settings"
                           FontSize="{DynamicResource TitleFontSize}"
                           FontWeight="SemiBold" />
                <TextBlock Text="Personalise AQI Clock on this computer."
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,4,0,24" />

                <TextBlock Text="General" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:CardControl Header="Start with Windows" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding StartWithWindows}" />
                </ui:CardControl>
                <ui:CardControl Header="Start minimised" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding StartMinimized}" />
                </ui:CardControl>
                <ui:CardControl Header="Close to notification area" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding CloseToTray}" />
                </ui:CardControl>
                <ui:CardControl Header="Theme" Margin="0,0,0,18" IsTabStop="False">
                    <ComboBox Width="170" ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}" />
                </ui:CardControl>

                <TextBlock Text="Display" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:CardControl Header="Always on top" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding AlwaysOnTop}" />
                </ui:CardControl>
                <ui:CardControl Header="Use compact mode on launch" Margin="0,0,0,18" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding CompactOnLaunch}" />
                </ui:CardControl>

                <TextBlock Text="Notifications" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:CardControl Header="Lesson starts" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding LessonStartNotifications}" />
                </ui:CardControl>
                <ui:CardControl Margin="0,0,0,6" IsTabStop="False">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="End warnings" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding EndWarningMinutes, StringFormat={}{0} minutes before the end}"
                                       FontSize="{DynamicResource CaptionFontSize}"
                                       Foreground="{DynamicResource MutedBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <StackPanel Width="250">
                        <ui:ToggleSwitch IsChecked="{Binding EndWarningNotifications}" HorizontalAlignment="Right" />
                        <Slider Minimum="0"
                                Maximum="15"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding EndWarningMinutes}"
                                IsEnabled="{Binding EndWarningNotifications}"
                                AutoToolTipPlacement="TopLeft"
                                AutoToolTipPrecision="0"
                                Margin="0,8,0,0" />
                    </StackPanel>
                </ui:CardControl>
                <ui:CardControl Header="Announcements" Margin="0,0,0,6" IsTabStop="False">
                    <ui:ToggleSwitch IsChecked="{Binding AnnouncementNotifications}" />
                </ui:CardControl>
                <ui:CardControl Header="Test Windows notifications" Margin="0,0,0,18" IsTabStop="False">
                    <ui:Button Content="Send test notification" Command="{Binding SendTestNotificationCommand}" />
                </ui:CardControl>

                <TextBlock Text="Account" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:CardControl Margin="0,0,0,6" IsTabStop="False">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{Binding Email}" FontWeight="SemiBold" />
                            <TextBlock Text="Signed-in account" FontSize="{DynamicResource CaptionFontSize}" Foreground="{DynamicResource MutedBrush}" />
                        </StackPanel>
                    </ui:CardControl.Header>
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="12" Padding="10,4">
                        <TextBlock Text="{Binding Role}" Foreground="White" FontWeight="SemiBold" />
                    </Border>
                </ui:CardControl>
                <ui:CardControl Header="Account actions" Margin="0,0,0,18" IsTabStop="False">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Sync now" Command="{Binding SyncNowCommand}" Margin="0,0,8,0" />
                        <ui:Button Content="Sign out" Command="{Binding SignOutCommand}" Appearance="Danger" />
                    </StackPanel>
                </ui:CardControl>

                <TextBlock Text="About" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" Margin="0,0,0,8" />
                <ui:CardControl Margin="0,0,0,6" IsTabStop="False">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="/AqiClock.App;component/assets/logo.png"
                                   Width="44"
                                   Height="44"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding Version, StringFormat=AQI Clock {0}}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding UpdateStatus}" FontSize="{DynamicResource CaptionFontSize}" Foreground="{DynamicResource MutedBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ui:Button Content="View logs" Command="{Binding ViewLogsCommand}" />
                </ui:CardControl>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2"
                Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Close" IsCancel="True" Margin="0,0,8,0" />
                <ui:Button Content="Save" Command="{Binding SaveCommand}" Appearance="Primary" IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
