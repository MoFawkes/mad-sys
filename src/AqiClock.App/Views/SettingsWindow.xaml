<Window x:Class="AqiClock.App.Views.SettingsWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Settings — AQI Clock" Width="600" Height="680" WindowStartupLocation="CenterOwner">
 <DockPanel Margin="22"><StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Save" Command="{Binding SaveCommand}" IsDefault="True"/><Button Content="Close" IsCancel="True"/></StackPanel><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
  <TextBlock Text="Settings" FontSize="30" FontWeight="Bold" Margin="0,0,0,18"/>
  <GroupBox Header="General" Padding="12" Margin="0,5"><StackPanel><CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}"/><CheckBox Content="Start minimised" IsChecked="{Binding StartMinimized}"/><CheckBox Content="Close to tray" IsChecked="{Binding CloseToTray}"/><ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Theme}"/></StackPanel></GroupBox>
  <GroupBox Header="Display" Padding="12" Margin="0,5"><StackPanel><CheckBox Content="Always on top" IsChecked="{Binding AlwaysOnTop}"/><CheckBox Content="Compact on launch" IsChecked="{Binding CompactOnLaunch}"/></StackPanel></GroupBox>
  <GroupBox Header="Notifications" Padding="12" Margin="0,5"><StackPanel><CheckBox Content="Lesson starts" IsChecked="{Binding LessonStartNotifications}"/><CheckBox Content="End warnings" IsChecked="{Binding EndWarningNotifications}"/><TextBlock Text="End warning minutes"/><Slider Minimum="0" Maximum="15" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding EndWarningMinutes}"/><CheckBox Content="Announcements" IsChecked="{Binding AnnouncementNotifications}"/></StackPanel></GroupBox>
  <GroupBox Header="Account" Padding="12" Margin="0,5"><StackPanel><TextBlock Text="{Binding Email}"/><TextBlock Text="{Binding Role}"/><WrapPanel><Button Content="Sync now" Command="{Binding SyncNowCommand}"/><Button Content="Sign out" Command="{Binding SignOutCommand}"/></WrapPanel></StackPanel></GroupBox>
  <GroupBox Header="About" Padding="12" Margin="0,5"><StackPanel><TextBlock Text="{Binding Version, StringFormat=AQI Clock {0}}"/><Button Content="View logs" Command="{Binding ViewLogsCommand}" HorizontalAlignment="Left"/></StackPanel></GroupBox>
 </StackPanel></ScrollViewer></DockPanel>
</Window>
