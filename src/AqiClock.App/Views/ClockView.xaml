<UserControl x:Class="AqiClock.App.Views.ClockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="{Binding TimeText}"
               FontSize="54"
               FontWeight="Light"
               HorizontalAlignment="Center" />
    <TextBlock Grid.Row="1"
               Text="{Binding DateText}"
               FontSize="{DynamicResource BodyFontSize}"
               HorizontalAlignment="Center"
               Foreground="{DynamicResource MutedBrush}"
               Margin="0,2,0,0" />
    <Border Grid.Row="2"
            Margin="16,18,16,12"
            Padding="22,16"
            Background="{DynamicResource WindowBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <StackPanel>
        <TextBlock Text="CURRENT LESSON"
                   FontSize="{DynamicResource CaptionFontSize}"
                   Foreground="{DynamicResource MutedBrush}"
                   HorizontalAlignment="Center" />
        <TextBlock Text="{Binding CurrentLesson}"
                   FontSize="{DynamicResource TitleFontSize}"
                   FontWeight="SemiBold"
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" />
        <TextBlock Text="{Binding CurrentDetail}"
                   Foreground="{DynamicResource MutedBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,4,0,0" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasCurrentLesson}" Value="False">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text="{Binding Remaining}"
                     FontSize="30"
                     FontWeight="SemiBold"
                     Foreground="{DynamicResource AccentBrush}" />
          <TextBlock Text=" remaining"
                     FontSize="{DynamicResource BodyFontSize}"
                     VerticalAlignment="Bottom"
                     Margin="5,0,0,4" />
        </StackPanel>
        <ProgressBar Height="8"
                     Maximum="100"
                     Value="{Binding Progress}"
                     Foreground="{DynamicResource AccentBrush}"
                     Margin="0,12,0,0">
          <ProgressBar.Style>
            <Style TargetType="ProgressBar">
              <Setter Property="Visibility" Value="Visible" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasCurrentLesson}" Value="False">
                  <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </ProgressBar.Style>
        </ProgressBar>
      </StackPanel>
    </Border>
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="4,6,4,2">
      <ui:SymbolIcon Symbol="ClockAlarm20" Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0" />
      <TextBlock Text="{Binding NextLesson}" FontSize="16" FontWeight="SemiBold" />
    </StackPanel>
  </Grid>
</UserControl>
