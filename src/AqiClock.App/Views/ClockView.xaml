<UserControl x:Class="AqiClock.App.Views.ClockView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition /></Grid.RowDefinitions>
    <TextBlock Text="{Binding TimeText}"
               FontSize="{DynamicResource DisplayFontSize}"
               FontWeight="Light"
               HorizontalAlignment="Center" />
    <TextBlock Grid.Row="1"
               Text="{Binding DateText}"
               FontSize="{DynamicResource BodyFontSize}"
               HorizontalAlignment="Center"
               Foreground="{DynamicResource MutedBrush}"
               Margin="0,2,0,0" />
    <Border Grid.Row="2"
            Margin="0,22,0,12"
            Padding="24"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
      <StackPanel>
        <TextBlock Text="{Binding CurrentLesson}" FontSize="{DynamicResource TitleFontSize}" FontWeight="SemiBold" />
        <TextBlock Text="{Binding CurrentDetail}" Foreground="{DynamicResource MutedBrush}" Margin="0,4,0,0" />
        <TextBlock Text="{Binding Remaining}" FontSize="24" FontWeight="SemiBold" Margin="0,12,0,0" />
        <ProgressBar Height="8" Maximum="100" Value="{Binding Progress}" Margin="0,14,0,0" />
      </StackPanel>
    </Border>
    <TextBlock Grid.Row="3" Text="{Binding NextLesson}" FontSize="18" FontWeight="SemiBold" Margin="4,8,4,10" />
    <ListBox Grid.Row="4" ItemsSource="{Binding TodayPeriods}" BorderThickness="0" Background="Transparent">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="HorizontalContentAlignment" Value="Stretch" />
          <Setter Property="Padding" Value="0" />
          <Setter Property="Margin" Value="0,2" />
          <Setter Property="Background" Value="Transparent" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}" /></Trigger>
          </Style.Triggers>
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border x:Name="PeriodRow" CornerRadius="8" Padding="12,9" Background="Transparent">
            <DockPanel>
              <TextBlock DockPanel.Dock="Right" Text="{Binding Time}" Foreground="{DynamicResource MutedBrush}" />
              <TextBlock x:Name="PeriodName" Text="{Binding Name}" FontWeight="SemiBold" />
            </DockPanel>
          </Border>
          <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
              <Setter TargetName="PeriodRow" Property="Background" Value="{DynamicResource AccentBrush}" />
              <Setter TargetName="PeriodName" Property="Foreground" Value="White" />
            </DataTrigger>
            <DataTrigger Binding="{Binding IsPast}" Value="True">
              <Setter TargetName="PeriodRow" Property="Opacity" Value="0.58" />
            </DataTrigger>
          </DataTemplate.Triggers>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
