<UserControl x:Class="AqiClock.App.Views.ClockView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="{Binding TimeText}" FontSize="64" FontWeight="Light" HorizontalAlignment="Center"/><TextBlock Grid.Row="1" Text="{Binding DateText}" FontSize="18" HorizontalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/><Border Grid.Row="2" Margin="0,22,0,12" Padding="22" Background="{DynamicResource CardBrush}" CornerRadius="12"><StackPanel><TextBlock Text="{Binding CurrentLesson}" FontSize="28" FontWeight="SemiBold"/><TextBlock Text="{Binding CurrentDetail}"/><TextBlock Text="{Binding Remaining}" FontSize="24"/><ProgressBar Height="8" Maximum="100" Value="{Binding Progress}" Margin="0,12,0,0"/></StackPanel></Border><TextBlock Grid.Row="3" Text="{Binding NextLesson}" FontSize="18" Margin="4,6"/><ListBox Grid.Row="4" ItemsSource="{Binding TodayPeriods}" BorderThickness="0" Background="Transparent"><ListBox.ItemTemplate><DataTemplate><DockPanel Margin="4"><TextBlock DockPanel.Dock="Right" Text="{Binding Time}" Foreground="{DynamicResource MutedBrush}"/><TextBlock Text="{Binding Name}" FontWeight="SemiBold"/></DockPanel></DataTemplate></ListBox.ItemTemplate></ListBox></Grid></UserControl>
