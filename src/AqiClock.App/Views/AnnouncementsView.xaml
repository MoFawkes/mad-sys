<UserControl x:Class="AqiClock.App.Views.AnnouncementsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ListBox ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent">
    <ListBox.ItemContainerStyle>
      <Style TargetType="ListBoxItem">
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Background" Value="Transparent" />
      </Style>
    </ListBox.ItemContainerStyle>
    <ListBox.ItemTemplate>
      <DataTemplate>
        <Border BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="2,16">
          <StackPanel>
            <DockPanel>
              <TextBlock DockPanel.Dock="Right"
                         Text="{Binding RelativeTime}"
                         FontSize="{DynamicResource CaptionFontSize}"
                         Foreground="{DynamicResource MutedBrush}"
                         Margin="12,2,0,0" />
              <TextBlock Text="{Binding Title}"
                         FontSize="16"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
            </DockPanel>
            <TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,7,0,8" LineHeight="20" />
            <TextBlock Text="{Binding Poster}"
                       FontSize="{DynamicResource CaptionFontSize}"
                       Foreground="{DynamicResource MutedBrush}" />
          </StackPanel>
        </Border>
      </DataTemplate>
    </ListBox.ItemTemplate>
  </ListBox>
</UserControl>
