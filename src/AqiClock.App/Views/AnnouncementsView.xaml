<UserControl x:Class="AqiClock.App.Views.AnnouncementsView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><ListBox ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent"><ListBox.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource MutedBrush}" BorderThickness="0,0,0,1" Padding="0,14"><StackPanel><DockPanel><TextBlock DockPanel.Dock="Right" Text="{Binding RelativeTime}" Foreground="{DynamicResource MutedBrush}"/><TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold"/></DockPanel><TextBlock Text="{Binding Body}" TextWrapping="Wrap" Margin="0,5"/><TextBlock Text="{Binding Poster}" Foreground="{DynamicResource MutedBrush}"/></StackPanel></Border></DataTemplate></ListBox.ItemTemplate></ListBox></UserControl>
