<ui:FluentWindow x:Class="AqiClock.App.Views.StudentClassPickerWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="Student session" Width="520" Height="650" WindowStartupLocation="CenterScreen"
  Background="{DynamicResource WindowBrush}" Loaded="OnLoaded">
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="Choose your class(es)" FontSize="{DynamicResource TitleFontSize}" FontWeight="Bold" Foreground="{DynamicResource HeaderBrush}"/>
      <TextBlock Text="This choice lasts for this app session only." Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,16"/>
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Classes}" Background="{DynamicResource CardBrush}">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="0" />
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate><DataTemplate><CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Padding="8"/></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
    <TextBlock Grid.Row="2" Text="Naseehah (optional)" FontWeight="SemiBold" Foreground="{DynamicResource HeaderBrush}" Margin="0,16,0,8"/>
    <ListBox Grid.Row="3" ItemsSource="{Binding NaseehahChoices}" Background="{DynamicResource CardBrush}">
      <ListBox.ItemContainerStyle>
        <Style TargetType="ListBoxItem">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Padding" Value="0" />
        </Style>
      </ListBox.ItemContainerStyle>
      <ListBox.ItemTemplate><DataTemplate><CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Padding="8"/></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
    <StackPanel Grid.Row="4" Margin="0,12,0,0">
      <TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <ui:Button Content="Start student session" Appearance="Primary" HorizontalAlignment="Right" Click="OnStart"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
