<ui:FluentWindow x:Class="AqiClock.App.Views.StudentClassPickerWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  Title="Student session" Width="520" Height="560" WindowStartupLocation="CenterScreen"
  Background="{DynamicResource WindowBrush}" Loaded="OnLoaded">
  <Grid Margin="28">
    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <StackPanel>
      <TextBlock Text="Choose your class(es)" FontSize="{DynamicResource TitleFontSize}" FontWeight="Bold" Foreground="{DynamicResource HeaderBrush}"/>
      <TextBlock Text="This choice lasts for this app session only." Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,16"/>
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Classes}" Background="{DynamicResource CardBrush}">
      <ListBox.ItemTemplate><DataTemplate><CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Padding="8"/></DataTemplate></ListBox.ItemTemplate>
    </ListBox>
    <ComboBox Grid.Row="2" ItemsSource="{Binding HalfDays}" SelectedItem="{Binding SelectedHalfDay}" Margin="0,16,0,8"/>
    <StackPanel Grid.Row="3">
      <TextBlock Text="{Binding Error}" Foreground="{DynamicResource ErrorBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
      <ui:Button Content="Start student session" Appearance="Primary" HorizontalAlignment="Right" Click="OnStart"/>
    </StackPanel>
  </Grid>
</ui:FluentWindow>
