<Window x:Class="AqiClock.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:views="clr-namespace:AqiClock.App.Views" Title="AQI Clock" Width="720" Height="760" MinWidth="520" MinHeight="540" Closing="OnClosing" LocationChanged="OnPlacementChanged" SizeChanged="OnPlacementChanged">
  <Window.Style><Style TargetType="Window"><Setter Property="WindowStyle" Value="SingleBorderWindow"/><Style.Triggers><DataTrigger Binding="{Binding DisplayMode}" Value="Compact"><Setter Property="WindowStyle" Value="None"/><Setter Property="ResizeMode" Value="NoResize"/><Setter Property="Width" Value="320"/><Setter Property="Height" Value="80"/><Setter Property="MinWidth" Value="320"/><Setter Property="MinHeight" Value="80"/></DataTrigger></Style.Triggers></Style></Window.Style>
  <Grid Background="{DynamicResource WindowBrush}" MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid.Style><Style TargetType="Grid"><Setter Property="Margin" Value="24"/><Style.Triggers><DataTrigger Binding="{Binding DisplayMode}" Value="Compact"><Setter Property="Margin" Value="10,6"/></DataTrigger></Style.Triggers></Style></Grid.Style>
    <Grid x:Name="NormalLayout"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
      <DockPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Content="Compact" Command="{Binding ToggleDisplayModeCommand}"/><Button Content="Pin" Command="{Binding TogglePinCommand}"/><Button Content="Settings" Command="{Binding OpenSettingsCommand}"/><Button Content="Edit timetables" Command="{Binding EditTimetablesCommand}"><Button.Style><Style TargetType="Button"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding IsAdmin}" Value="True"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></Button.Style></Button></StackPanel><TextBlock Text="AQI Clock" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/></DockPanel>
      <views:ClockView Grid.Row="1" DataContext="{Binding Clock}" Margin="0,20,0,10"/>
      <DockPanel Grid.Row="2"><Button DockPanel.Dock="Right" Command="{Binding ToggleAnnouncementsCommand}" Content="{Binding Announcements.UnreadCount, StringFormat=Announcements ({0})}"/><TextBlock Text="{Binding SyncStatus}" VerticalAlignment="Center" Foreground="{DynamicResource MutedBrush}"/></DockPanel>
    </Grid>
    <Grid x:Name="CompactLayout" Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Clock.TimeText}" FontSize="24" FontWeight="SemiBold"/><TextBlock Text="{Binding Clock.CurrentLesson}" FontSize="12"/></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal"><Button Content="↗" Command="{Binding ToggleDisplayModeCommand}"/><Button Content="📌" Command="{Binding TogglePinCommand}"/></StackPanel><ProgressBar Grid.ColumnSpan="2" Height="3" VerticalAlignment="Bottom" Maximum="100" Value="{Binding Clock.Progress}"/></Grid>
    <Border x:Name="AnnouncementPanel" Width="360" HorizontalAlignment="Right" Background="{DynamicResource CardBrush}" Padding="18" Visibility="Collapsed"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition/></Grid.RowDefinitions><DockPanel><Button DockPanel.Dock="Right" Content="Close" Command="{Binding ToggleAnnouncementsCommand}"/><TextBlock Text="Announcements" FontSize="22" FontWeight="Bold"/></DockPanel><views:AnnouncementsView Grid.Row="1" DataContext="{Binding Announcements}"/></Grid></Border>
  </Grid>
  <Window.Triggers>
    <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard/></BeginStoryboard></EventTrigger>
  </Window.Triggers>
</Window>
