<Window x:Class="AqiClock.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AqiClock.App.Views"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AQI Clock"
        Background="{DynamicResource WindowBrush}"
        Closing="OnClosing"
        LocationChanged="OnPlacementChanged"
        SizeChanged="OnPlacementChanged">
  <Grid Background="{DynamicResource WindowBrush}"
        TextElement.Foreground="{DynamicResource TextBrush}"
        MouseLeftButtonDown="OnMouseLeftButtonDown"
        MouseMove="OnMouseMove">
    <Grid.Style>
      <Style TargetType="Grid">
        <Setter Property="Margin" Value="24" />
        <Style.Triggers>
          <DataTrigger Binding="{Binding DisplayMode}" Value="Compact"><Setter Property="Margin" Value="10,6" /></DataTrigger>
        </Style.Triggers>
      </Style>
    </Grid.Style>
    <Grid x:Name="NormalLayout">
      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <ui:Button Width="112" Height="38" Command="{Binding ToggleDisplayModeCommand}" Margin="4,0">
            <StackPanel Orientation="Horizontal"><TextBlock Text="◫" Margin="0,0,7,0" /><TextBlock Text="Compact" /></StackPanel>
          </ui:Button>
          <ui:Button Width="112" Height="38" Command="{Binding TogglePinCommand}" Margin="4,0">
            <ui:Button.Style>
              <Style TargetType="{x:Type ui:Button}">
                <Setter Property="Appearance" Value="Secondary" />
                <Style.Triggers><DataTrigger Binding="{Binding AlwaysOnTop}" Value="True"><Setter Property="Appearance" Value="Primary" /></DataTrigger></Style.Triggers>
              </Style>
            </ui:Button.Style>
            <StackPanel Orientation="Horizontal"><TextBlock Text="⌖" Margin="0,0,7,0" /><TextBlock Text="Pin" /></StackPanel>
          </ui:Button>
          <ui:Button Width="112" Height="38" Command="{Binding OpenSettingsCommand}" Margin="4,0">
            <StackPanel Orientation="Horizontal"><TextBlock Text="⚙" Margin="0,0,7,0" /><TextBlock Text="Settings" /></StackPanel>
          </ui:Button>
          <ui:Button Width="128" Height="38" Command="{Binding EditTimetablesCommand}" Appearance="Primary" Margin="4,0">
            <ui:Button.Style>
              <Style TargetType="{x:Type ui:Button}">
                <Setter Property="Appearance" Value="Primary" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers><DataTrigger Binding="{Binding IsAdmin}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
              </Style>
            </ui:Button.Style>
            <StackPanel Orientation="Horizontal"><TextBlock Text="✎" Margin="0,0,7,0" /><TextBlock Text="Edit timetables" /></StackPanel>
          </ui:Button>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Image Source="/AqiClock.App;component/assets/logo.png"
                 Width="36"
                 Height="36"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="HighQuality"
                 Margin="0,0,10,0" />
          <TextBlock Text="AQI Clock" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </StackPanel>
      </DockPanel>
      <views:ClockView Grid.Row="1" DataContext="{Binding Clock}" Margin="0,20,0,10" />
      <Border Grid.Row="2"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="10"
              Padding="12,8">
        <DockPanel>
          <ui:Button DockPanel.Dock="Right" Command="{Binding ToggleAnnouncementsCommand}" Appearance="Transparent">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="●" Foreground="{DynamicResource AccentBrush}" Margin="0,0,7,0" />
              <TextBlock Text="Announcements" />
              <Border Background="{DynamicResource AccentBrush}" CornerRadius="10" Padding="7,2" Margin="8,0,0,0">
                <TextBlock Text="{Binding Announcements.UnreadCount}" Foreground="White" FontSize="{DynamicResource CaptionFontSize}" />
              </Border>
            </StackPanel>
          </ui:Button>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0" />
            <TextBlock Text="{Binding SyncStatus}" Foreground="{DynamicResource MutedBrush}" />
          </StackPanel>
        </DockPanel>
      </Border>
    </Grid>
    <Grid x:Name="CompactLayout" Visibility="Collapsed">
      <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding Clock.TimeText}" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="{Binding Clock.CurrentLesson}" FontSize="{DynamicResource CaptionFontSize}" Foreground="{DynamicResource MutedBrush}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal">
        <ui:Button Content="↗" ToolTip="Return to normal mode" Appearance="Transparent" Width="32" Height="32" Command="{Binding ToggleDisplayModeCommand}" />
        <ui:Button Content="⌖" ToolTip="Always on top" Width="32" Height="32" Command="{Binding TogglePinCommand}">
          <ui:Button.Style>
            <Style TargetType="{x:Type ui:Button}">
              <Setter Property="Appearance" Value="Transparent" />
              <Style.Triggers><DataTrigger Binding="{Binding AlwaysOnTop}" Value="True"><Setter Property="Appearance" Value="Primary" /></DataTrigger></Style.Triggers>
            </Style>
          </ui:Button.Style>
        </ui:Button>
      </StackPanel>
      <ProgressBar Grid.ColumnSpan="2" Height="3" VerticalAlignment="Bottom" Maximum="100" Value="{Binding Clock.Progress}" />
    </Grid>
    <Border x:Name="AnnouncementPanel"
            Width="380"
            HorizontalAlignment="Right"
            Background="{DynamicResource CardBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1,0,0,0"
            CornerRadius="12,0,0,12"
            Padding="20"
            Visibility="Collapsed">
      <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition /></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,12">
          <ui:Button DockPanel.Dock="Right" Content="Close" Appearance="Transparent" Command="{Binding ToggleAnnouncementsCommand}" />
          <ui:Button DockPanel.Dock="Right" Content="Compose / manage" Appearance="Primary" Command="{Binding ManageAnnouncementsCommand}" Margin="0,0,8,0">
            <ui:Button.Style>
              <Style TargetType="{x:Type ui:Button}">
                <Setter Property="Appearance" Value="Primary" />
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers><DataTrigger Binding="{Binding IsAdmin}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
              </Style>
            </ui:Button.Style>
          </ui:Button>
          <TextBlock Text="Announcements" FontSize="{DynamicResource SubtitleFontSize}" FontWeight="SemiBold" VerticalAlignment="Center" />
        </DockPanel>
        <views:AnnouncementsView Grid.Row="1" DataContext="{Binding Announcements}" />
      </Grid>
    </Border>
  </Grid>
  <Window.Triggers>
    <EventTrigger RoutedEvent="Loaded"><BeginStoryboard><Storyboard /></BeginStoryboard></EventTrigger>
  </Window.Triggers>
</Window>
