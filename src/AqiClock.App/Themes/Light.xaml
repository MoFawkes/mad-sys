<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <SolidColorBrush x:Key="HeaderBrush" Color="#112549"/>
  <SolidColorBrush x:Key="HighlightBrush" Color="#C89B3C"/>
  <SolidColorBrush x:Key="WindowBrush" Color="#F4F0E6"/>
  <SolidColorBrush x:Key="CardBrush" Color="#FFFCF5"/>
  <SolidColorBrush x:Key="TextBrush" Color="#15233D"/>
  <SolidColorBrush x:Key="MutedBrush" Color="#6B7280"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#2E6DD8"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="#107C10"/>
  <SolidColorBrush x:Key="CurrentPeriodBrush" Color="#DFE9F9"/>
  <SolidColorBrush x:Key="DividerBrush" Color="#D8D2C6"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#8A4F00"/>
  <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF4CE"/>
  <system:Double x:Key="DisplayFontSize">64</system:Double>
  <system:Double x:Key="TitleFontSize">28</system:Double>
  <system:Double x:Key="SubtitleFontSize">20</system:Double>
  <system:Double x:Key="BodyFontSize">14</system:Double>
  <system:Double x:Key="CaptionFontSize">12</system:Double>
</ResourceDictionary>
