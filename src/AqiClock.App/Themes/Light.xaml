<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <SolidColorBrush x:Key="WindowBrush" Color="#F7F8FA"/>
  <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
  <SolidColorBrush x:Key="TextBrush" Color="#1B1B1F"/>
  <SolidColorBrush x:Key="MutedBrush" Color="#5F6368"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#24457A"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="#C42B1C"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#8A4F00"/>
  <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#FFF4CE"/>
  <system:Double x:Key="DisplayFontSize">64</system:Double>
  <system:Double x:Key="TitleFontSize">28</system:Double>
  <system:Double x:Key="SubtitleFontSize">20</system:Double>
  <system:Double x:Key="BodyFontSize">14</system:Double>
  <system:Double x:Key="CaptionFontSize">12</system:Double>
</ResourceDictionary>
