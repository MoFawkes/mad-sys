<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:system="clr-namespace:System;assembly=System.Runtime">
  <SolidColorBrush x:Key="HeaderBrush" Color="#0B1933"/>
  <SolidColorBrush x:Key="HighlightBrush" Color="#D8AE55"/>
  <SolidColorBrush x:Key="WindowBrush" Color="#112549"/>
  <SolidColorBrush x:Key="CardBrush" Color="#1A2E52"/>
  <SolidColorBrush x:Key="TextBrush" Color="#F4F0E6"/>
  <SolidColorBrush x:Key="MutedBrush" Color="#B8C0CC"/>
  <SolidColorBrush x:Key="AccentBrush" Color="#72A1F1"/>
  <SolidColorBrush x:Key="SuccessBrush" Color="#6CCB5F"/>
  <SolidColorBrush x:Key="CurrentPeriodBrush" Color="#24446F"/>
  <SolidColorBrush x:Key="DividerBrush" Color="#405273"/>
  <SolidColorBrush x:Key="ErrorBrush" Color="#FF99A4"/>
  <SolidColorBrush x:Key="WarningBrush" Color="#FCE100"/>
  <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#433519"/>
  <system:Double x:Key="DisplayFontSize">64</system:Double>
  <system:Double x:Key="TitleFontSize">28</system:Double>
  <system:Double x:Key="SubtitleFontSize">20</system:Double>
  <system:Double x:Key="BodyFontSize">14</system:Double>
  <system:Double x:Key="CaptionFontSize">12</system:Double>
</ResourceDictionary>
