<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="WindowBrush" Color="#111827"/><SolidColorBrush x:Key="CardBrush" Color="#1F2937"/><SolidColorBrush x:Key="TextBrush" Color="#F3F4F6"/><SolidColorBrush x:Key="MutedBrush" Color="#A7B0C0"/><SolidColorBrush x:Key="AccentBrush" Color="#60A5FA"/>
  <Style TargetType="Window"><Setter Property="Background" Value="{StaticResource WindowBrush}"/><Setter Property="Foreground" Value="{StaticResource TextBrush}"/><Setter Property="FontFamily" Value="Segoe UI"/></Style>
  <Style TargetType="Button"><Setter Property="Padding" Value="12,6"/><Setter Property="Margin" Value="3"/></Style>
</ResourceDictionary>
