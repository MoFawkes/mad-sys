# Environment variables use the AQICLOCK_ prefix and __ for nested keys.
AQICLOCK_Supabase__Url=https://your-project.supabase.co
AQICLOCK_Supabase__AnonKey=your-public-anon-key
AQICLOCK_AqiClock__CacheFreshnessMinutes=60
# Optional for installed-update testing; blank/omitted disables updates in development.
AQICLOCK_Updates__RepositoryUrl=https://github.com/MoFawkes/aqi-clock-releases
